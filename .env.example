# EbookReader - Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Android Signing (for release builds) ─────────────────────────────────────
# SIGNING_KEY_ALIAS=your-key-alias
# SIGNING_KEY_PASSWORD=your-key-password
# SIGNING_STORE_PASSWORD=your-store-password
# SIGNING_KEY_STORE_PATH=path/to/keystore.jks

# ── Google Play (if publishing) ───────────────────────────────────────────────
# GOOGLE_PLAY_JSON_KEY_PATH=path/to/service-account.json
